---
import Container from '../../../components/Container.astro';
import TeamPage from '../../../components/TeamPage.astro';
import { getWorldCupSummary } from '../../../data/worldcup2026';
import { getCountryName } from '../../../i18n/countries';
import { useTranslations } from '../../../i18n/ui';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getTeamSlug, getTeamsFromMatches } from '../../../utils/teams';

export async function getStaticPaths() {
  const summary = await getWorldCupSummary();

  return getTeamsFromMatches(summary.matches).map((team) => ({
    params: { team: getTeamSlug(team.name) },
    props: { team },
  }));
}

const { team } = Astro.props;
const locale = 'en';
const t = useTranslations(locale);
const teamLabel = getCountryName(team.name, locale);
---

<BaseLayout title={`${teamLabel} | World Cup 2026`} description={t('team.metaDescription')} locale={locale}>
  <Container>
    <TeamPage locale={locale} team={team} />
  </Container>
</BaseLayout>
