---
import type { Locale } from '../config/site';
import { useTranslations } from '../i18n/ui';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);
---

<button
  class="theme-toggle"
  type="button"
  data-theme-toggle
  data-light-label={t('theme.light')}
  data-dark-label={t('theme.dark')}
  aria-label={t('theme.toggle')}
  aria-pressed="false"
>
  <span class="theme-toggle__icon" aria-hidden="true"></span>
  <span class="theme-toggle__text" data-theme-toggle-text>{t('theme.light')}</span>
</button>

<script>
  const storageKey = 'mundial2026-theme';
  const mediaQuery = window.matchMedia('(prefers-color-scheme: dark)');
  const toggle = document.querySelector('[data-theme-toggle]');
  const text = toggle?.querySelector('[data-theme-toggle-text]');

  function getStoredTheme() {
    try {
      const value = localStorage.getItem(storageKey);
      return value === 'dark' || value === 'light' ? value : null;
    } catch {
      return null;
    }
  }

  function getCurrentTheme() {
    return document.documentElement.dataset.theme || (mediaQuery.matches ? 'dark' : 'light');
  }

  function applyTheme(theme, persist = true) {
    document.documentElement.dataset.theme = theme;
    document.documentElement.style.colorScheme = theme;

    if (persist) {
      try {
        localStorage.setItem(storageKey, theme);
      } catch {
        // Ignore storage errors in private browsing or restricted contexts.
      }
    }

    updateToggle(theme);
  }

  function updateToggle(theme) {
    if (!toggle || !text) return;

    const isDark = theme === 'dark';
    toggle.setAttribute('aria-pressed', String(isDark));
    text.textContent = isDark ? toggle.dataset.darkLabel || 'Dark' : toggle.dataset.lightLabel || 'Light';
  }

  updateToggle(getCurrentTheme());

  toggle?.addEventListener('click', () => {
    applyTheme(getCurrentTheme() === 'dark' ? 'light' : 'dark');
  });

  mediaQuery.addEventListener('change', (event) => {
    if (!getStoredTheme()) {
      applyTheme(event.matches ? 'dark' : 'light', false);
    }
  });
</script>

<style>
  .theme-toggle {
    align-items: center;
    background: var(--color-surface-soft);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-full);
    color: var(--color-text-muted);
    cursor: pointer;
    display: inline-flex;
    font: inherit;
    font-size: 0.78rem;
    font-weight: 850;
    gap: var(--space-2);
    min-height: 2.25rem;
    padding: 0.35rem 0.7rem;
    transition: background var(--transition-base), border-color var(--transition-base), color var(--transition-base), transform var(--transition-fast);
  }

  .theme-toggle:hover {
    border-color: var(--color-border-strong);
    color: var(--color-text);
    transform: translateY(-1px);
  }

  .theme-toggle:focus-visible {
    outline: 3px solid color-mix(in srgb, var(--color-primary), transparent 25%);
    outline-offset: 3px;
  }

  .theme-toggle__icon {
    background: var(--color-primary);
    border-radius: var(--radius-full);
    box-shadow: inset -0.28rem -0.28rem 0 color-mix(in srgb, var(--color-surface), transparent 20%);
    flex: 0 0 auto;
    height: 0.9rem;
    width: 0.9rem;
  }

  [data-theme='dark'] .theme-toggle__icon {
    background: var(--color-accent);
    box-shadow: 0 0 0 0.22rem var(--color-accent-soft);
  }

  @media (max-width: 560px) {
    .theme-toggle__text {
      clip: rect(0, 0, 0, 0);
      border: 0;
      height: 1px;
      margin: -1px;
      overflow: hidden;
      padding: 0;
      position: absolute;
      white-space: nowrap;
      width: 1px;
    }
  }
</style>
