---
import BracketMatchCard from './BracketMatchCard.astro';
import type { Locale } from '../config/site';
import type { BracketRound } from '../utils/bracket';
import { useTranslations } from '../i18n/ui';

interface Props {
  locale: Locale;
  rounds: BracketRound[];
}

const { locale, rounds } = Astro.props;
const t = useTranslations(locale);
---

<section class="bracket-board-shell" aria-labelledby="bracket-board-title">
  <header class="bracket-board-header">
    <div>
      <p class="eyebrow">{t('bracket.boardEyebrow')}</p>
      <h2 id="bracket-board-title">{t('bracket.boardTitle')}</h2>
      <p>{t('bracket.boardHelp')}</p>
    </div>
    <div class="bracket-board-controls" aria-label={t('bracket.zoomControls')}>
      <button type="button" data-bracket-zoom-out aria-label={t('bracket.zoomOut')}>−</button>
      <button type="button" data-bracket-zoom-reset>{t('bracket.zoomReset')}</button>
      <button type="button" data-bracket-zoom-in aria-label={t('bracket.zoomIn')}>+</button>
    </div>
  </header>

  <div class="bracket-viewport" data-bracket-viewport tabindex="0" role="region" aria-label={t('bracket.boardRegion')}>
    <div class="bracket-stage" data-bracket-stage>
      {rounds.map((round, roundIndex) => (
        <section class="bracket-column" aria-labelledby={`board-${round.id}-title`} style={`--round-gap: ${Math.min(roundIndex, 4) * 2.25}rem`}>
          <h3 id={`board-${round.id}-title`}>{round.name}</h3>
          <div class="bracket-column__matches" role="list" aria-label={`${round.name}: ${t('bracket.matchesInRound')}`}>
            {round.matches.map((item) => (
              <div class="bracket-slot" role="listitem">
                <BracketMatchCard locale={locale} item={item} compact={true} />
              </div>
            ))}
          </div>
        </section>
      ))}
    </div>
  </div>
</section>

<script>
  const viewport = document.querySelector('[data-bracket-viewport]');
  const stage = document.querySelector('[data-bracket-stage]');
  const zoomInButton = document.querySelector('[data-bracket-zoom-in]');
  const zoomOutButton = document.querySelector('[data-bracket-zoom-out]');
  const zoomResetButton = document.querySelector('[data-bracket-zoom-reset]');

  let scale = 1;
  let isDragging = false;
  let lastX = 0;
  let lastY = 0;

  function applyScale() {
    if (!stage) return;
    stage.style.setProperty('--bracket-scale', String(scale));
  }

  function setScale(nextScale) {
    scale = Math.min(1.4, Math.max(0.55, Math.round(nextScale * 100) / 100));
    applyScale();
  }

  zoomInButton?.addEventListener('click', () => setScale(scale + 0.1));
  zoomOutButton?.addEventListener('click', () => setScale(scale - 0.1));
  zoomResetButton?.addEventListener('click', () => setScale(1));

  viewport?.addEventListener('wheel', (event) => {
    if (!event.ctrlKey && !event.metaKey) return;
    event.preventDefault();
    setScale(scale + (event.deltaY > 0 ? -0.08 : 0.08));
  }, { passive: false });

  viewport?.addEventListener('pointerdown', (event) => {
    if (!(event.target instanceof Element)) return;
    if (event.target.closest('a, button')) return;
    isDragging = true;
    lastX = event.clientX;
    lastY = event.clientY;
    viewport.setPointerCapture(event.pointerId);
    viewport.classList.add('is-dragging');
  });

  viewport?.addEventListener('pointermove', (event) => {
    if (!isDragging || !viewport) return;
    const deltaX = event.clientX - lastX;
    const deltaY = event.clientY - lastY;
    viewport.scrollLeft -= deltaX;
    viewport.scrollTop -= deltaY;
    lastX = event.clientX;
    lastY = event.clientY;
  });

  function stopDragging(event) {
    if (!viewport || !isDragging) return;
    isDragging = false;
    viewport.classList.remove('is-dragging');
    if (event.pointerId !== undefined) viewport.releasePointerCapture(event.pointerId);
  }

  viewport?.addEventListener('pointerup', stopDragging);
  viewport?.addEventListener('pointercancel', stopDragging);
  viewport?.addEventListener('pointerleave', stopDragging);

  viewport?.addEventListener('keydown', (event) => {
    if (!viewport) return;
    const distance = event.shiftKey ? 160 : 64;

    if (event.key === '+') setScale(scale + 0.1);
    if (event.key === '-') setScale(scale - 0.1);
    if (event.key === '0') setScale(1);
    if (event.key === 'ArrowRight') viewport.scrollLeft += distance;
    if (event.key === 'ArrowLeft') viewport.scrollLeft -= distance;
    if (event.key === 'ArrowDown') viewport.scrollTop += distance;
    if (event.key === 'ArrowUp') viewport.scrollTop -= distance;
  });

  applyScale();
</script>

<style>
  .bracket-board-shell {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-2xl);
    box-shadow: var(--shadow-xs);
    margin-top: var(--space-8);
    overflow: hidden;
  }

  .bracket-board-header {
    align-items: flex-start;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4);
    justify-content: space-between;
    padding: var(--space-5);
  }

  .eyebrow {
    color: var(--color-primary);
    font-size: 0.74rem;
    font-weight: 900;
    letter-spacing: 0.14em;
    margin: 0 0 var(--space-2);
    text-transform: uppercase;
  }

  h2,
  h3,
  p {
    margin-top: 0;
  }

  h2 {
    font-size: clamp(1.5rem, 6vw, 2.4rem);
    font-weight: 950;
    letter-spacing: -0.06em;
    line-height: 1.05;
    margin-bottom: var(--space-2);
  }

  .bracket-board-header p:not(.eyebrow) {
    color: var(--color-text-muted);
    line-height: 1.6;
    margin-bottom: 0;
    max-width: 46rem;
  }

  .bracket-board-controls {
    align-items: center;
    display: flex;
    gap: var(--space-2);
  }

  .bracket-board-controls button {
    background: var(--color-surface-soft);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    color: var(--color-text);
    cursor: pointer;
    font: inherit;
    font-weight: 900;
    min-height: 2.5rem;
    min-width: 2.5rem;
    padding: 0.5rem 0.75rem;
  }

  .bracket-board-controls button:hover {
    border-color: var(--color-border-strong);
    color: var(--color-primary);
  }

  .bracket-viewport {
    background:
      linear-gradient(90deg, color-mix(in srgb, var(--color-border), transparent 75%) 1px, transparent 1px),
      linear-gradient(color-mix(in srgb, var(--color-border), transparent 75%) 1px, transparent 1px),
      var(--color-surface-soft);
    background-size: 2rem 2rem;
    cursor: grab;
    max-height: min(72vh, 52rem);
    overflow: auto;
    overscroll-behavior: contain;
    padding: var(--space-6);
    touch-action: none;
  }

  .bracket-viewport.is-dragging {
    cursor: grabbing;
    user-select: none;
  }

  .bracket-viewport:focus-visible {
    outline: 3px solid color-mix(in srgb, var(--color-primary), transparent 25%);
    outline-offset: -3px;
  }

  .bracket-stage {
    --bracket-scale: 1;
    align-items: stretch;
    display: flex;
    gap: clamp(1.25rem, 3vw, 2rem);
    min-height: 36rem;
    min-width: max-content;
    padding: var(--space-2);
    transform: scale(var(--bracket-scale));
    transform-origin: top left;
    width: max-content;
  }

  .bracket-column {
    display: flex;
    flex: 0 0 19rem;
    flex-direction: column;
    gap: var(--space-4);
  }

  .bracket-column h3 {
    background: var(--color-primary);
    border-radius: var(--radius-full);
    color: var(--color-surface);
    font-size: 0.86rem;
    font-weight: 950;
    letter-spacing: 0.08em;
    margin: 0;
    padding: 0.6rem 0.85rem;
    text-align: center;
    text-transform: uppercase;
  }

  .bracket-column__matches {
    display: grid;
    gap: calc(1rem + var(--round-gap));
  }

  .bracket-slot {
    position: relative;
  }

  .bracket-slot::after {
    border-top: 2px solid var(--color-border-strong);
    content: '';
    display: none;
    height: 0;
    left: calc(100% + 0.25rem);
    position: absolute;
    top: 50%;
    width: 1.5rem;
  }

  .bracket-column:not(:last-child) .bracket-slot::after {
    display: block;
  }

  @media (max-width: 720px) {
    .bracket-board-header {
      padding: var(--space-4);
    }

    .bracket-viewport {
      max-height: 70vh;
      padding: var(--space-4);
    }

    .bracket-column {
      flex-basis: 17rem;
    }
  }
</style>
