---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { defaultLocale, siteConfig, type Locale } from '../config/site';
import { useTranslations } from '../i18n/ui';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  locale?: Locale;
}

const {
  title = siteConfig.name,
  image = 'og-image.svg',
  locale = defaultLocale,
} = Astro.props;

const t = useTranslations(locale);
const description = Astro.props.description ?? t('site.description');
const pageTitle = title === siteConfig.name ? title : `${title} · ${siteConfig.name}`;
const basePath = import.meta.env.BASE_URL ?? siteConfig.base;
const withBase = (path: string) => `${basePath.replace(/\/$/, '')}/${path.replace(/^\//, '')}`;
const canonicalUrl = new URL(Astro.url.pathname, siteConfig.url).toString();
const imageUrl = new URL(withBase(image), siteConfig.url).toString();
const ogLocale = locale === 'es' ? 'es_ES' : 'en_US';
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" type="image/svg+xml" href={withBase('favicon.svg')} />
    <link rel="icon" href={withBase('favicon.ico')} />
    <link rel="manifest" href={withBase('manifest.webmanifest')} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={imageUrl} />
    <meta property="og:locale" content={ogLocale} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageUrl} />
  </head>
  <body>
    <Header locale={locale} />
    <main>
      <slot />
    </main>
    <Footer locale={locale} />
  </body>
</html>
