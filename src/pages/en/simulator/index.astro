---
import Container from '../../../components/Container.astro';
import SimulatorRandomizer from '../../../components/SimulatorRandomizer.astro';
import WorldCupSimulator from '../../../components/WorldCupSimulator.astro';
import { getWorldCupSummary } from '../../../data/worldcup2026';
import { useTranslations } from '../../../i18n/ui';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import '../../../styles/simulator-dynamic.css';

const locale = 'en';
const t = useTranslations(locale);
const summary = await getWorldCupSummary();
---

<BaseLayout title={t('simulator.metaTitle')} description={t('simulator.metaDescription')} locale={locale}>
  <Container>
    <SimulatorRandomizer
      randomizeLabel={t('simulator.randomize')}
      shareLabel={t('simulator.share')}
      clearLabel={t('simulator.clearPrediction')}
      copiedLabel={t('simulator.shareCopied')}
    />
    <WorldCupSimulator locale={locale} summary={summary} />
  </Container>
</BaseLayout>
