---
import Breadcrumbs from './Breadcrumbs.astro';
import ContextualLinks from './ContextualLinks.astro';
import type { Locale } from '../config/site';
import type { WorldCupMatch, WorldCupSummary } from '../data/worldcup2026';
import { getCountryFlagUrl, getCountryName, isKnownCountry } from '../i18n/countries';
import { getLocalizedPath, getLocalizedRoutePath, useTranslations } from '../i18n/ui';
import type { SimulatorMatch } from '../scripts/simulator-model';

interface Props {
  locale: Locale;
  summary: WorldCupSummary;
}

const { locale, summary } = Astro.props;
const t = useTranslations(locale);
const homeUrl = getLocalizedPath('/', locale);
const calendarUrl = getLocalizedRoutePath('routes.calendar', locale);
const simulatorUrl = getLocalizedRoutePath('routes.simulator', locale);

function getGroupCode(groupName?: string) {
  return groupName?.match(/[A-Z]$/)?.[0] ?? '';
}

function getMatchId(match: WorldCupMatch, index: number) {
  return match.num ? `m${match.num}` : `i${index}`;
}

function getTeamPayload(team: string) {
  return {
    raw: team,
    label: getCountryName(team, locale),
    flag: getCountryFlagUrl(team),
    isCountry: isKnownCountry(team),
  };
}

const simulatorMatches: SimulatorMatch[] = summary.matches.map((match, index) => ({
  id: getMatchId(match, index),
  index,
  num: match.num ?? null,
  round: match.round,
  group: match.group ?? null,
  groupCode: getGroupCode(match.group),
  team1: getTeamPayload(match.team1),
  team2: getTeamPayload(match.team2),
  score1: match.score1 ?? null,
  score2: match.score2 ?? null,
}));

const simulatorData = {
  labels: {
    pickWinner: t('simulator.pickWinner'),
    simulated: t('simulator.simulated'),
    realResult: t('simulator.realResult'),
    pending: t('simulator.pending'),
    noChampion: t('simulator.noChampion'),
    unresolvedTeam: t('simulator.unresolvedTeam'),
    groupStage: t('simulator.groupStage'),
    knockoutStage: t('simulator.knockoutStage'),
    pickWinnerForMatch: t('a11y.pickWinnerForMatch'),
  },
  matches: simulatorMatches,
};
---

<section class="simulator-shell" aria-labelledby="simulator-title">
  <Breadcrumbs
    locale={locale}
    items={[
      { label: t('nav.home'), href: homeUrl },
      { label: t('nav.simulator'), href: simulatorUrl },
    ]}
  />

  <header class="simulator-hero">
    <div class="hero-content">
      <p class="eyebrow">{t('simulator.eyebrow')}</p>
      <h1 id="simulator-title">{t('simulator.title')}</h1>
      <p>{t('simulator.description')}</p>
      <button class="reset-button" type="button" data-reset-simulator>{t('simulator.reset')}</button>
    </div>
  </header>

  <aside class="champion-card" aria-live="polite" aria-labelledby="simulator-champion-label">
    <div>
      <span id="simulator-champion-label">{t('simulator.champion')}</span>
      <strong data-simulator-champion>{t('simulator.noChampion')}</strong>
    </div>
  </aside>

  <div class="simulator-board" data-simulator-board role="region" aria-label={t('a11y.simulatorBoard')}></div>

  <ContextualLinks
    title={t('home.detailsTitle')}
    links={[
      { label: t('nav.calendar'), href: calendarUrl, description: t('calendar.metaDescription') },
      { label: t('nav.home'), href: homeUrl, description: t('home.metaDescription') },
    ]}
  />
</section>

<script type="application/json" id="worldcup-simulator-data" set:html={JSON.stringify(simulatorData)}></script>
<script>import '../scripts/simulator-dom';</script>

<style>
  .simulator-shell {
    padding: var(--space-16) 0;
  }

  .simulator-hero {
    display: grid;
    gap: var(--space-8);
    padding: 0 0 var(--space-10);
  }

  .hero-content {
    max-width: 48rem;
  }

  .eyebrow {
    color: var(--color-primary);
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.16em;
    margin: 0 0 var(--space-3);
    text-transform: uppercase;
  }

  h1,
  p {
    margin-top: 0;
  }

  h1 {
    font-size: clamp(2.5rem, 12vw, 5.4rem);
    font-weight: 400;
    letter-spacing: -0.075em;
    line-height: 0.92;
    margin-bottom: var(--space-5);
  }

  .simulator-hero p:not(.eyebrow) {
    color: var(--color-text-muted);
    font-size: 1.05rem;
    line-height: 1.75;
  }

  .reset-button {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    color: var(--color-text);
    cursor: pointer;
    font: inherit;
    font-weight: 800;
    margin-top: var(--space-6);
    min-height: 2.9rem;
    padding: 0.85rem 1.1rem;
    transition: transform var(--transition-fast), border-color var(--transition-base), box-shadow var(--transition-base);
  }

  .reset-button:hover {
    border-color: var(--color-border-strong);
    box-shadow: var(--shadow-sm);
    transform: translateY(-1px);
  }

  .champion-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-2xl);
    box-shadow: var(--shadow-xs);
    margin-bottom: var(--space-6);
    padding: var(--space-5);
    position: sticky;
    top: var(--space-3);
    z-index: 4;
  }

  .champion-card div {
    align-items: center;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    justify-content: space-between;
  }

  .champion-card span {
    color: var(--color-primary);
    font-size: 0.72rem;
    font-weight: 900;
    letter-spacing: 0.15em;
    text-transform: uppercase;
  }

  .champion-card strong {
    align-items: center;
    display: inline-flex;
    gap: var(--space-2);
    font-size: clamp(1.25rem, 6vw, 2.1rem);
    font-weight: 800;
    letter-spacing: -0.045em;
    line-height: 1;
  }

  .simulator-board {
    contain: layout style;
  }

  .simulator-board :global(.sim-round) {
    content-visibility: auto;
    contain-intrinsic-size: 48rem;
  }

  .simulator-board :global(.sim-match),
  .simulator-board :global(.sim-group-table) {
    content-visibility: auto;
    contain-intrinsic-size: 10rem;
  }

  @media (max-width: 560px) {
    .simulator-board :global(.sim-round) {
      contain-intrinsic-size: 64rem;
    }
  }
</style>
