---
import Container from '../../components/Container.astro';
import MatchDetailPage from '../../components/MatchDetailPage.astro';
import { defaultLocale } from '../../config/site';
import { getWorldCupSummary } from '../../data/worldcup2026';
import { getCountryName } from '../../i18n/countries';
import { useTranslations } from '../../i18n/ui';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { findMatchBySlug, getMatchSlug } from '../../utils/matches';

export async function getStaticPaths() {
  const summary = await getWorldCupSummary();

  return summary.matches.map((match) => ({
    params: { match: getMatchSlug(match) },
    props: { match },
  }));
}

const { match } = Astro.props;
const locale = defaultLocale;
const t = useTranslations(locale);
const title = `${getCountryName(match.team1, locale)} ${t('home.versus')} ${getCountryName(match.team2, locale)} | Mundial 2026`;
---

<BaseLayout title={title} description={t('match.metaDescription')} locale={locale}>
  <Container>
    <MatchDetailPage locale={locale} match={match} />
  </Container>
</BaseLayout>
