---
import Container from '../../../components/Container.astro';
import WorldCupSimulator from '../../../components/WorldCupSimulator.astro';
import { getWorldCupSummary } from '../../../data/worldcup2026';
import { useTranslations } from '../../../i18n/ui';
import BaseLayout from '../../../layouts/BaseLayout.astro';

const locale = 'en';
const t = useTranslations(locale);
const summary = await getWorldCupSummary();
---

<BaseLayout title={t('simulator.metaTitle')} description={t('simulator.metaDescription')} locale={locale}>
  <Container>
    <WorldCupSimulator locale={locale} summary={summary} />
  </Container>
</BaseLayout>
