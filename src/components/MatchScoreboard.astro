---
import TeamLink from './TeamLink.astro';
import type { Locale } from '../config/site';
import type { WorldCupMatch } from '../data/worldcup2026';
import { getCountryName } from '../i18n/countries';
import { useTranslations } from '../i18n/ui';
import { getMatchResult } from '../utils/matches';

interface Props {
  locale: Locale;
  match: WorldCupMatch;
}

const { locale, match } = Astro.props;
const t = useTranslations(locale);
const result = getMatchResult(match);
const scoreParts = result === '-' ? ['-', '-'] : result.split(' - ');
const team1Label = getCountryName(match.team1, locale);
const team2Label = getCountryName(match.team2, locale);
---

<section class="score-card" aria-label={`${team1Label} ${result} ${team2Label}`}>
  <div class="score-team">
    <TeamLink locale={locale} team={match.team1} flagSize={46} />
    <strong>{scoreParts[0]}</strong>
  </div>
  <span class="score-separator">{t('home.versus')}</span>
  <div class="score-team score-team-away">
    <TeamLink locale={locale} team={match.team2} flagSize={46} />
    <strong>{scoreParts[1]}</strong>
  </div>
</section>

<style>
  .score-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-2xl);
    box-shadow: var(--shadow-xs);
    display: grid;
    gap: var(--space-3);
    margin-bottom: var(--space-6);
    padding: var(--space-5);
  }

  .score-team {
    align-items: center;
    background: var(--color-surface-soft);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    display: grid;
    gap: var(--space-3);
    grid-template-columns: minmax(0, 1fr) auto;
    padding: var(--space-4);
  }

  .score-team strong {
    align-items: center;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    display: inline-flex;
    font-size: 2rem;
    font-weight: 950;
    justify-content: center;
    min-height: 3.4rem;
    min-width: 3.8rem;
  }

  .score-team-away {
    text-align: left;
  }

  .score-separator {
    color: var(--color-text-soft);
    font-size: 0.75rem;
    font-weight: 950;
    justify-self: center;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  @media (min-width: 720px) {
    .score-card {
      align-items: center;
      grid-template-columns: minmax(0, 1fr) auto minmax(0, 1fr);
    }
  }
</style>
