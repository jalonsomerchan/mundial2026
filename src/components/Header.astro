---
import Container from './Container.astro';
import { localeLabels, siteConfig, type Locale } from '../config/site';
import { getAlternateLocales, getLocalizedPath, getLocalizedRoutePath, useTranslations } from '../i18n/ui';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);
const homeUrl = getLocalizedPath('/', locale);
const calendarUrl = getLocalizedRoutePath('routes.calendar', locale);
const alternateLocales = getAlternateLocales(locale);
---

<header class="border-b border-[var(--color-border)] bg-[var(--color-surface)]/85 backdrop-blur">
  <Container class="flex items-center justify-between gap-4 py-4">
    <a class="font-black tracking-tight text-[var(--color-text)]" href={homeUrl}>{siteConfig.name}</a>
    <nav aria-label="Navegación principal" class="flex items-center gap-3 text-sm text-[var(--color-text-muted)]">
      <a class="font-semibold hover:text-[var(--color-text)]" href={homeUrl}>{t('nav.home')}</a>
      <a class="font-semibold hover:text-[var(--color-text)]" href={calendarUrl}>{t('nav.calendar')}</a>
      {alternateLocales.map((alternateLocale) => (
        <a
          class="rounded-full border border-[var(--color-border)] px-3 py-1 text-xs font-bold hover:text-[var(--color-text)]"
          href={getLocalizedPath('/', alternateLocale)}
          hreflang={alternateLocale}
        >
          {localeLabels[alternateLocale]}
        </a>
      ))}
    </nav>
  </Container>
</header>
