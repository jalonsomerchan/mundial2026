---
import Container from '../components/Container.astro';
import WorldCupExplorer from '../components/WorldCupExplorer.astro';
import { defaultLocale, siteConfig } from '../config/site';
import { getWorldCupSummary } from '../data/worldcup2026';
import BaseLayout from '../layouts/BaseLayout.astro';
import { useTranslations } from '../i18n/ui';

const locale = defaultLocale;
const t = useTranslations(locale);
const summary = await getWorldCupSummary();
---

<BaseLayout title={t('home.metaTitle')} description={t('home.metaDescription')} locale={locale}>
  <Container>
    <WorldCupExplorer locale={locale} summary={summary} />
  </Container>
</BaseLayout>
