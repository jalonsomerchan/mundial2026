---
import Container from '../../components/Container.astro';
import WorldCupExplorer from '../../components/WorldCupExplorer.astro';
import { defaultLocale, locales, type Locale } from '../../config/site';
import { getWorldCupSummary } from '../../data/worldcup2026';
import { isLocale, useTranslations } from '../../i18n/ui';
import BaseLayout from '../../layouts/BaseLayout.astro';

export function getStaticPaths() {
  return locales
    .filter((locale) => locale !== defaultLocale)
    .map((locale) => ({
      params: { locale },
    }));
}

const localeParam = Astro.params.locale;
const locale: Locale = isLocale(localeParam) ? localeParam : defaultLocale;
const t = useTranslations(locale);
const summary = await getWorldCupSummary();
---

<BaseLayout title={t('home.metaTitle')} description={t('home.metaDescription')} locale={locale}>
  <Container>
    <WorldCupExplorer locale={locale} summary={summary} />
  </Container>
</BaseLayout>
