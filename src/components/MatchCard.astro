---
import TeamLink from './TeamLink.astro';
import type { Locale } from '../config/site';
import type { WorldCupMatch } from '../data/worldcup2026';
import { getCountryName } from '../i18n/countries';
import { useTranslations } from '../i18n/ui';
import { getMatchResult, getMatchUtcIso } from '../utils/matches';

interface Props {
  locale: Locale;
  match: WorldCupMatch;
}

const { locale, match } = Astro.props;
const t = useTranslations(locale);
const matchIso = getMatchUtcIso(match);
const result = getMatchResult(match);

function getTeamLabel(team: string) {
  return getCountryName(team, locale);
}
---

<article class="match-card">
  <header class="match-header">
    <div class="match-kicker">
      <span class="match-badge">{match.group ?? match.round}</span>
      <span class="match-countdown js-match-countdown" data-match-time={matchIso}>{t('home.countdownPending')}</span>
    </div>
    <time class="match-date-time" datetime={matchIso}>
      <span class="js-local-date" datetime={matchIso}>{match.date}</span>
      <span aria-hidden="true">·</span>
      <span class="js-local-time" datetime={matchIso}>{match.time}</span>
    </time>
  </header>

  <div class="scoreboard" aria-label={`${getTeamLabel(match.team1)} ${result} ${getTeamLabel(match.team2)}`}>
    <div class="team-row">
      <strong class="team-info"><TeamLink locale={locale} team={match.team1} flagSize={34} /></strong>
      <span class="team-score" aria-label={`${t('home.result')}: ${result}`}>{result === '-' ? '-' : result.split(' - ')[0]}</span>
    </div>

    <div class="team-row">
      <strong class="team-info"><TeamLink locale={locale} team={match.team2} flagSize={34} /></strong>
      <span class="team-score">{result === '-' ? '-' : result.split(' - ')[1]}</span>
    </div>
  </div>

  <dl class="match-details">
    <div>
      <dt>{t('home.round')}</dt>
      <dd>{match.round}</dd>
    </div>
    <div>
      <dt>{t('home.venue')}</dt>
      <dd>{match.ground}</dd>
    </div>
  </dl>
</article>

<style>
  .match-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-2xl);
    box-shadow: var(--shadow-xs);
    min-width: 0;
    overflow: hidden;
    padding: var(--space-5);
    transition:
      transform var(--transition-base),
      border-color var(--transition-base),
      box-shadow var(--transition-base);
  }

  .match-card:hover {
    border-color: var(--color-border-strong);
    box-shadow: var(--shadow-sm);
    transform: translateY(-2px);
  }

  .match-header {
    display: grid;
    gap: var(--space-3);
    margin-bottom: var(--space-5);
  }

  .match-kicker {
    align-items: center;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    justify-content: space-between;
  }

  .match-badge,
  .match-countdown,
  .match-date-time {
    align-items: center;
    border-radius: var(--radius-full);
    display: inline-flex;
    font-size: 0.8rem;
    font-weight: 850;
    gap: 0.35rem;
    padding: 0.35rem 0.7rem;
  }

  .match-badge,
  .match-date-time {
    background: var(--color-primary-soft);
    color: var(--color-primary);
  }

  .match-countdown {
    background: var(--color-accent-soft);
    color: var(--color-accent);
  }

  .match-date-time {
    justify-content: center;
    width: 100%;
  }

  .scoreboard {
    background: var(--color-surface-soft);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    display: grid;
    gap: var(--space-2);
    padding: var(--space-3);
  }

  .team-row {
    align-items: center;
    display: grid;
    gap: var(--space-3);
    grid-template-columns: minmax(0, 1fr) auto;
    min-width: 0;
  }

  .team-info {
    color: var(--color-text);
    display: block;
    font-size: clamp(1.05rem, 4.6vw, 1.35rem);
    font-weight: 850;
    letter-spacing: -0.03em;
    line-height: 1.15;
    min-width: 0;
  }

  .team-score {
    align-items: center;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    color: var(--color-text);
    display: inline-flex;
    font-size: 1.45rem;
    font-weight: 950;
    justify-content: center;
    line-height: 1;
    min-height: 2.75rem;
    min-width: 3rem;
    padding: 0 var(--space-3);
  }

  .match-details {
    display: grid;
    gap: var(--space-3);
    margin: var(--space-4) 0 0;
  }

  .match-details div {
    background: var(--color-surface-soft);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-3);
  }

  dt {
    color: var(--color-text-soft);
    font-size: 0.7rem;
    font-weight: 850;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  dd {
    color: var(--color-text-muted);
    font-size: 0.95rem;
    font-weight: 750;
    line-height: 1.35;
    margin: var(--space-1) 0 0;
  }

  @media (min-width: 560px) {
    .match-details {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }
</style>
