---
interface Props {
  randomizeLabel: string;
  shareLabel: string;
  clearLabel: string;
  copiedLabel: string;
  actionsLabel?: string;
}

const { randomizeLabel, shareLabel, clearLabel, copiedLabel, actionsLabel = 'Simulator actions' } = Astro.props;
---

<div class="simulator-randomizer" data-simulator-actions role="group" aria-label={actionsLabel}>
  <button class="random-button" type="button" data-randomize-simulator>{randomizeLabel}</button>
  <button class="share-button" type="button" data-share-simulator>{shareLabel}</button>
  <button class="clear-button" type="button" data-clear-simulator>{clearLabel}</button>
  <p class="share-feedback" aria-live="polite" data-share-feedback></p>
</div>

<script define:vars={{ copiedLabel }}>
  const storageKey = 'worldcup-2026-simulator-v1';
  const predictionQueryKey = 'p';
  const randomizeButton = document.querySelector('[data-randomize-simulator]');
  const shareButton = document.querySelector('[data-share-simulator]');
  const clearButton = document.querySelector('[data-clear-simulator]');
  const feedback = document.querySelector('[data-share-feedback]');

  // El aleatorio pesado anterior usaba getAvailableMatches y disparaba muchos clicks con Math.random.
  // Ahora se delega en worldCupSimulator.randomize(), que calcula la predicción sin escanear el DOM.

  function encodePrediction(prediction) {
    const json = JSON.stringify(prediction);
    const bytes = new TextEncoder().encode(json);
    let binary = '';
    bytes.forEach((byte) => {
      binary += String.fromCharCode(byte);
    });

    return btoa(binary).replace(/\+/g, '-').replace(/\//g, '_').replace(/=+$/g, '');
  }

  function decodePrediction(value) {
    try {
      const base64 = value.replace(/-/g, '+').replace(/_/g, '/');
      const padded = base64.padEnd(Math.ceil(base64.length / 4) * 4, '=');
      const binary = atob(padded);
      const bytes = Uint8Array.from(binary, (character) => character.charCodeAt(0));
      const parsed = JSON.parse(new TextDecoder().decode(bytes));

      return parsed && typeof parsed === 'object' && !Array.isArray(parsed) ? parsed : null;
    } catch {
      return null;
    }
  }

  function loadSharedPrediction() {
    const sharedPrediction = new URLSearchParams(window.location.search).get(predictionQueryKey);
    if (!sharedPrediction) return;

    const prediction = decodePrediction(sharedPrediction);
    if (prediction) {
      localStorage.setItem(storageKey, JSON.stringify(prediction));
      document.dispatchEvent(new CustomEvent('simulator:picks-loaded'));
    }
  }

  function getStoredPrediction() {
    try {
      const storedPrediction = JSON.parse(localStorage.getItem(storageKey) || '{}');
      return storedPrediction && typeof storedPrediction === 'object' && !Array.isArray(storedPrediction)
        ? storedPrediction
        : {};
    } catch {
      return {};
    }
  }

  function buildShareUrl() {
    const url = new URL(window.location.href);
    url.searchParams.set(predictionQueryKey, encodePrediction(getStoredPrediction()));
    url.hash = '';

    return url.toString();
  }

  async function sharePrediction() {
    const url = buildShareUrl();

    if (navigator.share) {
      try {
        await navigator.share({ url });
      } catch {
        return;
      }
    } else if (navigator.clipboard) {
      await navigator.clipboard.writeText(url);
    }

    if (feedback) {
      feedback.textContent = copiedLabel;
    }
  }

  function cleanPredictionUrl() {
    const url = new URL(window.location.href);
    url.searchParams.delete(predictionQueryKey);
    window.history.replaceState({}, '', url);
  }

  function randomizeSimulator() {
    window.worldCupSimulator?.randomize();
  }

  function clearPrediction() {
    localStorage.removeItem(storageKey);
    cleanPredictionUrl();
    window.worldCupSimulator?.clear();

    if (feedback) {
      feedback.textContent = '';
    }
  }

  loadSharedPrediction();
  randomizeButton?.addEventListener('click', randomizeSimulator);
  shareButton?.addEventListener('click', sharePrediction);
  clearButton?.addEventListener('click', clearPrediction);
</script>
